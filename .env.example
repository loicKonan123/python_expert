# Copie ce fichier en .env (déjà dans .gitignore) puis remplis tes valeurs.
# Toutes les variables sont préfixées par PYEXPERT_.

# ===== Choix du provider LLM =====
# ollama : LLM local via Ollama (autonome, plus lent)
# deepseek : API DeepSeek (qualité + vitesse, payant ~0.0008$/question)
PYEXPERT_LLM_PROVIDER=ollama

# ===== Provider Ollama (si llm_provider=ollama) =====
# PYEXPERT_OLLAMA_MODEL=qwen2.5-coder:7b
# PYEXPERT_OLLAMA_KEEP_ALIVE=30m

# ===== Provider DeepSeek (si llm_provider=deepseek) =====
# Crée ta clé sur https://platform.deepseek.com/api_keys
# PYEXPERT_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PYEXPERT_DEEPSEEK_MODEL=deepseek-chat       # V4-Flash non-thinking (recommandé)
# PYEXPERT_DEEPSEEK_MODEL=deepseek-reasoner   # V4-Flash thinking (plus lent)
# PYEXPERT_DEEPSEEK_MODEL=deepseek-v4-pro     # qualité max, ~5x plus cher

# ===== Divers =====
# PYEXPERT_LOG_LEVEL=INFO       # DEBUG pour plus de verbosité
# PYEXPERT_PORT=8000
# PYEXPERT_TOP_K=7              # nombre de chunks injectés dans le prompt
